# App
NODE_ENV=development
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# MongoDB Atlas
# Cluster: AgoraBOT | Database: Agorabot2
MONGODB_URI=mongodb+srv://USER:PASSWORD@HOST/?retryWrites=true&w=majority
MONGODB_DB_NAME=Agorabot2

# Security
JWT_SECRET=replace-with-strong-secret
# Usado apenas pelo script npm run create-admin (nunca commitar)
ADMIN_PASSWORD=replace-with-strong-admin-password
INTERNAL_API_TOKEN=replace-with-internal-admin-token
ENCRYPTION_KEY=32-byte-minimum-secret-for-token-encryption

# IA
GROQ_API_KEY=replace-with-groq-key
GROQ_MODEL=llama-3.3-70b-versatile

# Meta fallback for webhook verification when account verifyToken is not yet in MongoDB
META_VERIFY_TOKEN=replace-with-meta-verify-token
META_GRAPH_VERSION=v22.0

# Z-API defaults. Account-level configs in MongoDB override these values.
ZAPI_BASE_URL=https://api.z-api.io
ZAPI_CLIENT_TOKEN=
